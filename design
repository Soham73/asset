import 'package:flutter/material.dart';

void main() {
  runApp(MaterialApp(
    home: LeapYear(),
  ));
}
class LeapYear extends StatefulWidget {
  const LeapYear({super.key});

  @override
  State<LeapYear> createState() => _LeapYearState();
}

class _LeapYearState extends State<LeapYear> {
  TextEditingController year = TextEditingController();
  String result = "";

  void checkYear() {
    int y = int.parse(year.text);

    setState(() {
      if ((y % 4 == 0 && y % 100 != 0) || (y % 400 == 0)) {
        result = "$y is Leap Year";
      } else {
        result = "$y is Not Leap Year";
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text("Leap Year Checker")),

      body: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [

          TextField(
            controller: year,
            keyboardType: TextInputType.number,
            decoration: InputDecoration(labelText: "Enter Year"),
          ),

          SizedBox(height: 20),

          ElevatedButton(
            onPressed: checkYear,
            child: Text("Check"),
          ),

          SizedBox(height: 20),

          Text(
            result,
            style: TextStyle(fontSize: 25),
          )
        ],
      ),
    );
  }
}



